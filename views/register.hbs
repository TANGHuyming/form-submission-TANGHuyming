<main class="max-w-7xl mx-auto bg-gray-100 p-4 rounded-md shadow-lg shadow-gray-500 space-y-5">
    <h2
        class="font-bold text-2xl text-blue-500 text-center"
    >
        <div class="py-2 px-4 rounded-md bg-blue-200">
            Registration Form 📋
        </div>
    </h2>

    <form action="/register" method="POST" enctype="multipart/form-data"
        class="grid grid-cols-[20%_1fr] gap-2"
    >
        <label for="name" class="text-xl font-semibold">Full Name: </label>
        <input type="text" id="name" name="name" placeholder="Your name..." required
            class="p-2 font-medium text-lg border-2 border-gray-400 rounded-md"
        >
        
        <label for="email" class="text-xl font-semibold">Email Address: </label>
        <input type="email" id="email" name="email" placeholder="youremail@xxx.xxx..." required
            class="p-2 font-medium text-lg border-2 border-gray-400 rounded-md"
        >

        <label for="courses" class="text-xl font-semibold">Course Track: </label>
        <select name="courses" id="courses"
            class="p-2 font-medium text-lg border-2 border-gray-400 rounded-md"
        >
            {{#each courses}}
                <option value="{{this}}">{{this}}</option>
            {{/each}}
        </select>

        <label for="image" class="text-xl font-semibold">Profile Picture: </label>
        <input type="file" id="image" name="image" accept=".jpg, .jpeg, .png, image/jpg, image/png, image/jpeg" required
            class="p-2 font-medium text-lg border-2 border-gray-400 rounded-md cursor-pointer"
        >

        <button type="submit" class="text-xl font-semibold col-span-2 bg-green-300 p-2 hover:bg-green-500 cursor-pointer">
            Submit
        </button>

    </form>
</main>